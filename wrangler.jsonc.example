{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cassandra-portal",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./frontend/dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    {
      "binding": "MCP_KEYS",
      "id": "<your-mcp-keys-kv-namespace-id>"
    }
  ],
  "d1_databases": [
    {
      "binding": "PORTAL_DB",
      "database_name": "cassandra-portal",
      "database_id": "<your-d1-database-id>"
    }
  ],
  "services": [
    {
      "binding": "ACL_SERVICE",
      "service": "cassandra-acl"
    }
  ],
  "routes": [
    {
      "pattern": "<subdomain>.<domain>/*",
      "zone_name": "<domain>"
    }
  ],
  "observability": {
    "enabled": true
  },
  "dev": {
    "port": 8791
  }
}
